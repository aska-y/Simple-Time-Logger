# Gitに上げないファイル

# ======================
#  本プロジェクト固有
# ======================
html/
Memo.txt

# ======================
#  全般
# ======================
# ログファイルを無視
*.log

# 一時ファイルを無視
*.tmp
*.temp

# OS固有のファイルを無視
.DS_Store
Thumbs.db

# vscode
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace


# ======================
#  backend
# ======================

#  バイトコンパイルファイル
__pycache__/
*.py[cod]
*$py.class

# 仮想環境
.venv/

# 配布パッケージ
dist/
build/
*.egg-info/
.eggs/

# テストカバレッジ
.coverage
.pytest_cache/
htmlcov/

# Django
db.sqlite3


# ======================
#  frontend
# ======================
# dependencies
node_modules/

# build output
build/
dist/

# env variables (セキュリティのため必須)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

.env.staging

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

